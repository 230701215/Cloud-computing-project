# Azure Storage (server-side only — never commit real secrets)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=files

# API
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# Firebase Admin (server-side)
# IMPORTANT: Provide these from your Firebase service account JSON.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Note: keep the literal \n sequences (or set via secrets manager)
FIREBASE_PRIVATE_KEY=

# Firebase client (Vite) - put these into a local `.env` file (not committed)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

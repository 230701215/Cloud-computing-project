# Azure Storage (server-side only — never commit real secrets)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=files

# API
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# Local dev: simulate Easy Auth + user claims (omit in Azure App Service)
MOCK_EASY_AUTH=1
MOCK_USER_EMAIL=dev@local.test
MOCK_USER_NAME=Local Dev
# MOCK_USER_PICTURE=https://example.com/avatar.png
